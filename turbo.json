{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "cli:build": {
      "cache": false,
      "dependsOn": ["^cli:build"]
    },
    "cli:test": {
      "cache": true,
      "dependsOn": ["cli:build"]
    },
    "cli:lint": {
      "cache": true,
      "dependsOn": ["cli:build"]
    }
  }
}

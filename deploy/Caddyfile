# Caddyfile — TLS terminator / reverse proxy for the Objectified production spine.
#
# Used by docker-compose.prod.yml. Caddy obtains and renews Let's Encrypt certificates
# automatically (HTTP-01 / TLS-ALPN-01), so the only inbound ports the host must expose are
# 80 (ACME + HTTP→HTTPS redirect) and 443 (HTTPS). The REST API and MCP server are NOT
# published on the host in production — Caddy reaches them over the internal compose network
# by service name (rest:8000, mcp:8765).
#
# Configuration comes from the environment (set in your root .env; see
# docker-compose.prod.env.example):
#   DEPLOY_API_DOMAIN   public hostname for the REST API   (e.g. api.example.com)
#   DEPLOY_MCP_DOMAIN   public hostname for the MCP server (e.g. mcp.example.com)
#   ACME_EMAIL          contact address Let's Encrypt uses for expiry notices
#
# Caddy substitutes {$VAR} from its environment at load time.

{
	# ACME account contact. Required for production certificate issuance.
	email {$ACME_EMAIL}
}

# ─────────────────────────────── REST API ───────────────────────────────
{$DEPLOY_API_DOMAIN} {
	encode gzip zstd

	# Security headers. HSTS opts the domain into HTTPS-only for a year (preload-eligible).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy rest:8000 {
		# Surface the real client identity to the app behind the proxy.
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		# Caddy already retries idempotent requests; fail fast if REST is unhealthy.
		health_uri /livez
		health_interval 10s
		health_timeout 4s
	}
}

# ─────────────────────────────── MCP server ──────────────────────────────
{$DEPLOY_MCP_DOMAIN} {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy mcp:8765 {
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		health_uri /health
		health_interval 10s
		health_timeout 4s
	}
}

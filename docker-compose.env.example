# Copy to `.env` in the repo root (same directory as docker-compose.yml) to override defaults.

# Postgres (must match across postgres / migrate / mcp)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=objectified_local_dev
# POSTGRES_DB=objectified

# Host port mapping (optional)
# POSTGRES_PUBLISH_PORT=5432

# REST HTTP port on the host (objectified-rest always listens on 8000 in-container)
# OBJECTIFIED_REST_HTTP_PORT=8000

# MCP HTTP port on the host (must match in-container OBJECTIFIED_MCP_HTTP_PORT)
# OBJECTIFIED_MCP_HTTP_PORT=8765

# Required by objectified-mcp at runtime (min 16 characters); compose supplies a dev default
# OBJECTIFIED_MCP_INTERNAL_SECRET=replace-with-at-least-16-chars

# objectified-rest auth/CORS hardening (see docs/security/AUTH_MODEL.md).
# The Postgres credentials above are DEV-ONLY defaults — override them for any non-local use.
# In production set OBJECTIFIED_ENV=production AND a strong shared JWT secret, or REST refuses
# to start (it will not fall back to the insecure built-in default).
# OBJECTIFIED_ENV=development
# NEXTAUTH_SECRET=replace-with-output-of: openssl rand -base64 32
# OBJECTIFIED_CORS_ALLOWED_ORIGINS=https://app.example.com

# Optional objectified-mcp overrides (defaults documented in objectified-mcp/docs/CONFIGURATION.md)
# OBJECTIFIED_MCP_LOG_LEVEL=INFO
# OBJECTIFIED_MCP_DATABASE_POOL_MIN_SIZE=1
# OBJECTIFIED_MCP_DATABASE_POOL_MAX_SIZE=10
# OBJECTIFIED_MCP_DATABASE_POOL_TIMEOUT=30
# OBJECTIFIED_MCP_OPENAPI_MAX_JSON_BYTES=2097152

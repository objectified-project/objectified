# objectified-browse configuration
#
# Copy this file to `.env` and adjust the values, then restart the app:
#   cp .env.example .env
#
# Next.js loads `.env` automatically for `yarn dev`, `yarn build`, and `yarn start`.
# The `yarn docker:run` script also passes it to the container via `--env-file .env`.

# ---------------------------------------------------------------------------
# REST API  (required)
# ---------------------------------------------------------------------------
# Base URL of the objectified-rest API, including the `/v1` suffix.
#
# Browse builds the OpenAPI, Swagger, Arazzo, and JSON-Schema spec links from this
# value. When it is unset the app falls back to http://localhost:8000/v1 — which is
# exactly why those links point at localhost. Set this to the URL of your REST API
# as reached FROM THE USER'S BROWSER (these specs are fetched/downloaded client-side),
# so it must be publicly reachable and have CORS configured for this site's origin.
#
# Examples:
#   NEXT_PUBLIC_REST_API_BASE_URL=https://api.example.com/v1
#   NEXT_PUBLIC_REST_API_BASE_URL=http://localhost:8000/v1   # local development
NEXT_PUBLIC_REST_API_BASE_URL=http://localhost:8000/v1

# ---------------------------------------------------------------------------
# Hosting sub-path  (optional)
# ---------------------------------------------------------------------------
# Serve the app under a sub-path (e.g. https://example.com/browse). Leave unset to
# serve from the root. This is applied at BUILD time (next.config.ts), so set it
# before `yarn build` / building the Docker image.
# NEXT_PUBLIC_BASE_PATH=/browse

# ---------------------------------------------------------------------------
# Database (PostgreSQL)  — server-side only
# ---------------------------------------------------------------------------
# Browse reads catalog data directly from the objectified database. Provide EITHER
# a single DATABASE_URL, OR the discrete POSTGRES_* settings below (the discrete
# values take precedence when both are set).
#
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/objectified

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=objectified
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

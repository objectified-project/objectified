    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "mustache": "^4.2.0",
    "next": "^16.2.3",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "5.5.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",

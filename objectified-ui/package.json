{
  "name": "objectified-ui",
  "version": "0.11.41",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --verbose",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage --verbose",
    "test:import": "jest import-validation --verbose",
    "test:verbose": "jest --verbose --no-coverage",
    "test:db-helper": "jest db-helper --verbose",
    "test:detailed": "jest --verbose --no-coverage --forceExit",
    "test:setup": "./scripts/setup-test-db.sh",
    "test:responses": "jest helper-shared-path-responses --verbose",
    "test:responses:coverage": "jest helper-shared-path-responses --coverage --verbose",
    "test:response-node": "jest PathResponseNode --verbose",
    "test:response-linking": "jest paths-canvas-response-linking --verbose",
    "test:all-responses": "jest helper-shared-path-responses PathResponseNode paths-canvas-response-linking OperationPropertiesPanel-responses --verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "docker:build": "./build-docker.sh",
    "docker:build:fast": "./build-docker.sh --no-test",
    "docker:build:package": "./build-docker.sh --package",
    "docker:build:push": "./build-docker.sh --push",
    "docker:run": "docker rm -f objectified-ui 2>/dev/null || true; docker run -d -p 8000:3000 --env-file .env --name objectified-ui --restart unless-stopped objectified-ui:latest",
    "docker:stop": "docker stop objectified-ui",
    "docker:start": "docker start objectified-ui",
    "docker:restart": "docker restart objectified-ui",
    "docker:logs": "docker logs -f objectified-ui",
    "docker:remove": "docker stop objectified-ui 2>/dev/null || true && docker rm objectified-ui"
  },
  "dependencies": {

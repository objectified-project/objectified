{
  "name": "objectified-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "docker:build": "./build-docker.sh",
    "docker:build:fast": "./build-docker.sh --no-test",
    "docker:build:package": "./build-docker.sh --package",
    "docker:build:push": "./build-docker.sh --push",
    "docker:run": "docker rm -f objectified-ui 2>/dev/null || true; docker run -d -p 8000:3000 --env-file .env --name objectified-ui --restart unless-stopped objectified-ui:latest",
    "docker:stop": "docker stop objectified-ui",
    "docker:start": "docker start objectified-ui",
    "docker:restart": "docker restart objectified-ui",
    "docker:logs": "docker logs -f objectified-ui",
    "docker:remove": "docker stop objectified-ui 2>/dev/null || true && docker rm objectified-ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.9.2",
    "bcrypt": "^6.0.0",
    "dagre": "^0.8.5",
    "diff": "^8.0.2",
    "json-schema-faker": "^0.5.9",
    "lucide-react": "^0.548.0",
    "mermaid": "^11.12.2",
    "next": "16.0.7",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6",
    "@types/diff": "^7.0.2",
    "@types/node": "^20",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

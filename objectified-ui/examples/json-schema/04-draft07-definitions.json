{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/order.json",
  "title": "Order",
  "description": "Order schema using draft-07 with definitions (legacy format)",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "pattern": "^ORD-[0-9]{8}$"
    },
    "customer": {
      "$ref": "#/definitions/Customer"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/OrderItem"
      },
      "minItems": 1
    },
    "shippingAddress": {
      "$ref": "#/definitions/Address"
    },
    "billingAddress": {
      "$ref": "#/definitions/Address"
    },
    "status": {
      "$ref": "#/definitions/OrderStatus"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["orderId", "customer", "items", "shippingAddress", "status"],
  "definitions": {
    "Customer": {
      "type": "object",
      "description": "Customer information",
      "properties": {
        "customerId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        }
      },
      "required": ["customerId", "name", "email"]
    },
    "OrderItem": {
      "type": "object",
      "description": "An item in the order",
      "properties": {
        "productId": {
          "type": "string"
        },
        "productName": {
          "type": "string"
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        },
        "unitPrice": {
          "type": "number",
          "minimum": 0
        },
        "totalPrice": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": ["productId", "productName", "quantity", "unitPrice"]
    },
    "Address": {
      "type": "object",
      "description": "Shipping or billing address",
      "properties": {
        "name": {
          "type": "string"
        },
        "line1": {
          "type": "string"
        },
        "line2": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "zipCode": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      },
      "required": ["name", "line1", "city", "state", "zipCode", "country"]
    },
    "OrderStatus": {
      "type": "string",
      "description": "Current status of the order",
      "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled", "refunded"]
    }
  }
}


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/person.json",
  "title": "Person",
  "description": "A simple person schema for testing basic JSON Schema import",
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string",
      "description": "The person's first name",
      "minLength": 1,
      "maxLength": 100
    },
    "lastName": {
      "type": "string",
      "description": "The person's last name",
      "minLength": 1,
      "maxLength": 100
    },
    "age": {
      "type": "integer",
      "description": "Age in years",
      "minimum": 0,
      "maximum": 150
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    }
  },
  "required": ["firstName", "lastName"]
}


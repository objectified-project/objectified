{
{{#if description}}  "description": "{{description}}",{{/if}}
{{#if type}}  "type": "{{type}}",{{/if}}
{{#if $ref}}  "$ref": "{{$ref}}",{{/if}}
{{#if format}}  "format": "{{format}}",{{/if}}
{{#if properties}}  "properties": {
{{#each properties}}
    "{{@key}}": {{{json this}}}{{#unless @last}},{{/unless}}
{{/each}}
  },{{/if}}
{{#if required}}  "required": [{{#each required}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],{{/if}}
{{#if items}}  "items": {{{json items}}},{{/if}}
{{#if enum}}  "enum": {{{json enum}}},{{/if}}
{{#if pattern}}  "pattern": "{{pattern}}",{{/if}}
{{#if minLength}}  "minLength": {{minLength}},{{/if}}
{{#if maxLength}}  "maxLength": {{maxLength}},{{/if}}
{{#if minimum}}  "minimum": {{minimum}},{{/if}}
{{#if maximum}}  "maximum": {{maximum}}{{/if}}
}


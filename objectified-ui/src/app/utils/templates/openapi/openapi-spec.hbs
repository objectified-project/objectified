{
  "openapi": "{{openapi}}",
  "info": {{{json info}}},
{{#if xMetadata}}  "x-metadata": {{{json xMetadata}}},
{{/if}}  "paths": {{{json paths}}},
  "components": {
    "schemas": {
{{#each schemas}}
      "{{@key}}": {{{json this}}}{{#unless @last}},{{/unless}}
{{/each}}
    }{{#if securitySchemes}},
    "securitySchemes": {{{json securitySchemes}}}
{{/if}}
  }
}

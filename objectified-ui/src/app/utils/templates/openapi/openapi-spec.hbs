{
  "openapi": "{{openapi}}",
  "info": {{{json info}}},
{{#if xMetadata}}  "x-metadata": {{{json xMetadata}}},
{{/if}}{{#if servers}}  "servers": {{{json servers}}},
{{/if}}{{#if tags}}  "tags": {{{json tags}}},
{{/if}}{{#if security}}  "security": {{{json security}}},
{{/if}}{{#if externalDocs}}  "externalDocs": {{{json externalDocs}}},
{{/if}}  "paths": {{{json paths}}},
  "components": {
    "schemas": {
{{#each schemas}}
      "{{@key}}": {{{json this}}}{{#unless @last}},{{/unless}}
{{/each}}
    }{{#if securitySchemes}},
    "securitySchemes": {{{json securitySchemes}}}
{{/if}}
  }
}

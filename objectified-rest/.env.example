# Database configuration
# DATABASE_URL=postgresql://postgres:password@localhost:5432/objectified
#
# Local dev: PostgreSQL must be running and the database must exist before `yarn dev` / uvicorn.
#   psql -U postgres -h localhost -p 5432 -c 'CREATE DATABASE objectified;'
# Then run migrations in order from objectified-db/scripts (see objectified-db/docs/README.md).

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# JWT Authentication (must match objectified-ui NEXTAUTH_SECRET)
NEXTAUTH_SECRET=your-nextauth-secret-here


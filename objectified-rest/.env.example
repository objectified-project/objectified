# Database configuration
# DATABASE_URL=postgresql://postgres:password@localhost:5432/objectified
#
# Local dev: PostgreSQL must be running and the database must exist before `yarn dev` / uvicorn.
#   psql -U postgres -h localhost -p 5432 -c 'CREATE DATABASE objectified;'
# Then run migrations in order from objectified-db/scripts (see objectified-db/docs/README.md).

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Deployment environment. Set to "production" for any non-local deployment: this enables
# fail-closed checks (the JWT secret below MUST be set or the service refuses to start).
# OBJECTIFIED_ENV=development

# JWT Authentication (must match objectified-ui NEXTAUTH_SECRET).
# Generate a strong value, e.g.: openssl rand -base64 32
# Required in production — there is no insecure built-in fallback there.
NEXTAUTH_SECRET=your-nextauth-secret-here

# CORS allow-list (optional). Comma-separated exact origins permitted to call the API.
# Defaults to the local Next.js dev ports when unset.
# OBJECTIFIED_CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Regex for trusted subdomains (defaults to *.objectified.dev). Set empty to disable.
# OBJECTIFIED_CORS_ALLOWED_ORIGIN_REGEX=https://.*\.example\.com

# SSRF guard (#3612). User-supplied URLs (import-from-URL, public repository
# registration) are rejected if they resolve to non-public addresses. Set to
# true ONLY for local development that imports from localhost/private hosts.
# OBJECTIFIED_SSRF_ALLOW_PRIVATE=false

# Per-tenant rate limiting (#3612). Disable with =false. Authenticated traffic
# (API key / JWT) uses the higher limit; public traffic uses the lower one.
# Limits are per replica (in-process counter).
# OBJECTIFIED_RATE_LIMIT_ENABLED=true
# OBJECTIFIED_RATE_LIMIT_AUTHENTICATED_PER_MINUTE=600
# OBJECTIFIED_RATE_LIMIT_PUBLIC_PER_MINUTE=120
# OBJECTIFIED_RATE_LIMIT_WINDOW_SECONDS=60

# Observability & error handling (#3617, RC1-3.2). Structured JSON logs, request-id
# propagation, and the ops dashboard.
# OBJECTIFIED_LOG_LEVEL=INFO            # DEBUG/INFO/WARNING/ERROR/CRITICAL
# OBJECTIFIED_LOG_JSON=true             # set false for human-friendly console logs in local dev
# OBJECTIFIED_REQUEST_ID_HEADER=X-Request-ID

# Backup status on the ops dashboard (reads RC1-1.3 backup manifests, #3613). Point this at the
# same directory the backup tooling writes to (OBJECTIFIED_BACKUP_DIR). When unset, backup status
# is reported as "unconfigured" rather than failing.
# OBJECTIFIED_BACKUP_DIR=/var/backups/objectified
# OBJECTIFIED_BACKUP_STALE_AFTER_HOURS=24   # latest backup older than this is flagged "stale"

